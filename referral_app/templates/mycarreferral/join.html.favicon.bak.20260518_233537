<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Join {{ rep.name }}'s Referral Network — MyCarReferral</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'Inter',sans-serif; background:#f8fafc; }
header { background:#1E293B; padding:16px 20px; display:flex; justify-content:space-between; align-items:center; }
.logo { color:#00C851; font-size:20px; font-weight:800; text-decoration:none; }
.logo span { color:white; font-weight:400; }
.container { max-width:560px; margin:0 auto; padding:24px 16px; }
.rep-card { background:#1E293B; border-radius:16px; padding:32px; text-align:center; margin-bottom:20px; }
.rep-photo { width:80px; height:80px; border-radius:50%; border:3px solid #00C851; object-fit:cover; margin:0 auto 14px; display:block; }
.rep-tag { font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#00C851; margin-bottom:8px; }
.rep-card h1 { font-size:22px; font-weight:800; color:white; margin-bottom:4px; }
.rep-card p { font-size:14px; color:rgba(255,255,255,0.5); }
.how-card { background:white; border-radius:16px; padding:24px; margin-bottom:20px; box-shadow:0 2px 8px rgba(0,0,0,0.06); }
.how-card h2 { font-size:15px; font-weight:800; color:#1E293B; margin-bottom:16px; text-transform:uppercase; letter-spacing:1px; }
.step { display:flex; gap:14px; align-items:flex-start; margin-bottom:14px; }
.step-num { background:#00C851; color:#1E293B; font-size:12px; font-weight:800; width:26px; height:26px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.step-text h4 { font-size:13px; font-weight:700; color:#1E293B; }
.step-text p { font-size:12px; color:#94A3B8; margin-top:2px; line-height:1.4; }
.form-card { background:white; border-radius:16px; padding:24px; box-shadow:0 2px 8px rgba(0,0,0,0.06); }
.form-card h2 { font-size:16px; font-weight:800; color:#1E293B; margin-bottom:4px; }
.form-card p { font-size:13px; color:#94A3B8; margin-bottom:20px; }
.field { margin-bottom:14px; }
label { display:block; font-size:12px; font-weight:600; color:#374151; margin-bottom:5px; }
input { width:100%; padding:12px 14px; border:2px solid #E2E8F0; border-radius:10px; font-size:15px; outline:none; font-family:'Inter',sans-serif; }
input:focus { border-color:#00C851; }
.submit-btn { width:100%; background:#00C851; color:#1E293B; border:none; padding:16px; border-radius:12px; font-size:15px; font-weight:800; cursor:pointer; margin-top:8px; }
.err { display:none; color:#ef4444; font-size:12px; text-align:center; margin-top:8px; }
.success-state { display:none; text-align:center; padding:20px 0; }
.success-state .emoji { font-size:48px; margin-bottom:12px; }
.success-state h3 { font-size:20px; font-weight:800; color:#00C851; margin-bottom:8px; }
.success-state p { font-size:13px; color:#64748B; line-height:1.6; margin-bottom:16px; }
.tracking-box { background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; padding:14px; font-size:12px; color:#166534; word-break:break-all; }
.login-link { text-align:center; margin-top:16px; font-size:13px; color:#64748B; }
.login-link a { color:#00C851; font-weight:600; text-decoration:none; }
footer { background:#1E293B; padding:20px; text-align:center; margin-top:40px; }
footer p { color:rgba(255,255,255,0.4); font-size:12px; }
</style>
</head>
<body>
<header>
  <a href="/" class="logo"><span>My</span>CarReferral</a>
</header>

<div class="container">
  <div class="rep-card">
    {% if rep.profile_photo %}
    <img src="{{ rep.profile_photo }}" class="rep-photo" alt="{{ rep.name }}">
    {% endif %}
    <div class="rep-tag">Personal Invitation</div>
    <h1>Join {{ rep.name }}'s Referral Network</h1>
    <p>{{ rep.dealership_name }} · {{ rep.city }}</p>
  </div>

  <div class="how-card">
    <h2>How It Works</h2>
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-text"><h4>Sign up in 30 seconds</h4><p>Enter your name, email, and phone below.</p></div>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-text"><h4>Send buyers {{ rep.name.split()[0] }}'s way</h4><p>Know someone shopping for a car? Submit their info from your dashboard.</p></div>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-text"><h4>They buy — you receive a gift</h4><p>Every closed deal earns you a Thank You gift from the dealership.</p></div>
    </div>
    <div class="step">
      <div class="step-num">4</div>
      <div class="step-text"><h4>Track everything at mycarreferral.com</h4><p>Your personal dashboard shows every referral and gift status in real time.</p></div>
    </div>
  </div>

  <div class="form-card">
    <h2>Join {{ rep.name.split()[0] }}'s Network</h2>
    <p>Sign up free. Takes 30 seconds. Get your dashboard instantly.</p>
    <div id="joinForm">
      <div class="field">
        <label>Your Full Name *</label>
        <input type="text" id="j_name" placeholder="John Smith">
      </div>
      <div class="field">
        <label>Your Email *</label>
        <input type="email" id="j_email" placeholder="john@email.com">
      </div>
      <div class="field">
        <label>Your Phone *</label>
        <input type="tel" id="j_phone" placeholder="732-555-1234">
      </div>
      <div id="joinErr" class="err">Please fill in all fields.</div>
      <button class="submit-btn" id="joinBtn" onclick="joinNetwork()">Join the Network →</button>
    </div>
    <div class="success-state" id="joinSuccess">
      <div class="emoji">🎉</div>
      <h3>You're in!</h3>
      <p>Check your email for your personal dashboard link.<br>Bookmark it to track every referral and gift.</p>
      <div class="tracking-box" id="trackingBox"></div>
      <div class="login-link" style="margin-top:16px;"><a href="/dashboard">Go to My Dashboard →</a></div>
    </div>
  </div>
</div>

<footer>
  <p>© 2026 MyCarReferral. Powered by CarsInStock.</p>
</footer>

<script>
var repTeamMemberId = {{ rep.id }};
async function joinNetwork() {
  var name = document.getElementById('j_name').value.trim();
  var email = document.getElementById('j_email').value.trim();
  var phone = document.getElementById('j_phone').value.trim();
  var err = document.getElementById('joinErr');
  if (!name || !email || !phone) { err.style.display='block'; return; }
  err.style.display='none';
  var btn = document.getElementById('joinBtn');
  btn.textContent = 'Joining...'; btn.disabled = true;
  var r = await fetch('/api/join', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({name:name, email:email, phone:phone, team_member_id:repTeamMemberId})
  });
  var d = await r.json();
  if (d.success) {
    document.getElementById('joinForm').style.display = 'none';
    document.getElementById('joinSuccess').style.display = 'block';
    if (d.token) {
      document.getElementById('trackingBox').innerHTML = '🔗 Your dashboard: <strong>https://mycarreferral.com/dashboard</strong><br>Login with your phone number.';
    }
  } else {
    btn.textContent = 'Join the Network →'; btn.disabled = false;
    err.textContent = d.error || 'Something went wrong.'; err.style.display='block';
  }
}
</script>
</body>
</html>
