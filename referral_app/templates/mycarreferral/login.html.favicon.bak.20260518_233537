<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login — MyCarReferral</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'Inter',sans-serif; background:#f8fafc; min-height:100vh; display:flex; flex-direction:column; }
header { background:#1E293B; padding:16px 20px; display:flex; justify-content:space-between; align-items:center; }
.logo { color:#00C851; font-size:20px; font-weight:800; text-decoration:none; }
.logo span { color:white; font-weight:400; }
.main { flex:1; display:flex; align-items:center; justify-content:center; padding:40px 20px; }
.card { background:white; border-radius:20px; padding:40px; max-width:420px; width:100%; box-shadow:0 4px 24px rgba(0,0,0,0.08); }
.card-icon { font-size:48px; text-align:center; margin-bottom:16px; }
.card h1 { font-size:24px; font-weight:800; color:#1E293B; text-align:center; margin-bottom:8px; }
.card p { font-size:14px; color:#64748B; text-align:center; margin-bottom:28px; line-height:1.5; }
.error { background:#fef2f2; border:1px solid #fecaca; color:#dc2626; padding:12px 16px; border-radius:8px; font-size:13px; margin-bottom:20px; }
label { display:block; font-size:13px; font-weight:600; color:#374151; margin-bottom:6px; }
input { width:100%; padding:14px 16px; border:2px solid #E2E8F0; border-radius:10px; font-size:16px; outline:none; font-family:'Inter',sans-serif; }
input:focus { border-color:#00C851; }
.submit-btn { width:100%; background:#00C851; color:#1E293B; border:none; padding:16px; border-radius:10px; font-size:16px; font-weight:800; cursor:pointer; margin-top:16px; }
.footer-link { text-align:center; margin-top:20px; font-size:13px; color:#64748B; }
.footer-link a { color:#00C851; font-weight:600; text-decoration:none; }
footer { background:#1E293B; padding:20px; text-align:center; }
footer p { color:rgba(255,255,255,0.4); font-size:12px; }
</style>
</head>
<body>
<header>
  <a href="/" class="logo"><span>My</span>CarReferral</a>
</header>
<div class="main">
  <div class="card">
    <div class="card-icon">🐦</div>
    <h1>Check My Referrals</h1>
    <p>Enter your phone number to access your personal referral dashboard.</p>
    {% if error %}
    <div class="error">{{ error }}</div>
    {% endif %}
    <form method="POST" action="/login">
      <label for="phone">Your Phone Number</label>
      <input type="tel" id="phone" name="phone" placeholder="e.g. 732-555-1234" required autofocus>
      <button type="submit" class="submit-btn">Access My Dashboard →</button>
    </form>
    <div class="footer-link">Not signed up yet? <a href="/">Learn how to join →</a></div>
  </div>
</div>
<footer>
  <p>© 2026 MyCarReferral. Powered by CarsInStock.</p>
</footer>
</body>
</html>
