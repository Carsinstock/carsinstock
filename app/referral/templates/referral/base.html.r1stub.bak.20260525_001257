<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}MyCarReferral{% endblock %}</title>
<style>
body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; margin: 0; padding: 20px; background: #F8FAFC; color: #0F172A; }
.mcr-stub { max-width: 480px; margin: 40px auto; padding: 24px; background: #FFFFFF; border-radius: 12px; }
.mcr-stub h1 { font-size: 22px; color: #1E293B; margin-top: 0; }
.mcr-stub p { color: #475569; line-height: 1.5; }
.mcr-stub .note { background: #FFF8EC; border-left: 3px solid #B8893F; padding: 10px 14px; border-radius: 4px; font-size: 13px; color: #475569; margin: 16px 0; }
</style>
{% block extra_head %}{% endblock %}
</head>
<body>
{% block content %}{% endblock %}
</body>
</html>
